---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <main>
    <section class="hero">
      <h1>🌍 Newcomer Health Literacy Initiative</h1>

      <p>
        Helping newcomers confidently navigate the Canadian healthcare system
        through accessible education, multilingual resources, and community
        workshops.
      </p>

      <div class="buttons">
        <a href="#">Explore Resources</a>
        <a href="#">Register for Workshops</a>
      </div>
    </section>
  </main>
</Layout>

<style>
main{
    max-width:1100px;
    margin:auto;
    padding:80px 20px;
    font-family:Arial, Helvetica, sans-serif;
}

.hero{
    text-align:center;
}

h1{
    font-size:3rem;
    margin-bottom:20px;
}

p{
    font-size:1.3rem;
    max-width:750px;
    margin:auto;
    line-height:1.6;
    color:#555;
}

.buttons{
    margin-top:40px;
    display:flex;
    justify-content:center;
    gap:20px;
    flex-wrap:wrap;
}

.buttons a{
    background:#0b74de;
    color:white;
    text-decoration:none;
    padding:15px 28px;
    border-radius:10px;
    font-weight:bold;
}

.buttons a:hover{
    background:#085cb0;
}
</style>