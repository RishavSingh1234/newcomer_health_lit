---
import Navbar from "../components/Navbar.astro";

interface Props {
  title?: string;
}

const { title = "Newcomer Health Literacy Initiative" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <meta
      name="description"
      content="Helping newcomers navigate the Canadian healthcare system through clear, accessible health education."
    />

    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
  </head>

  <body>
    <Navbar />

    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  :root {
    font-family:
      Inter,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;

    color: #16302f;
    background: #ffffff;
  }

  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    line-height: 1.6;
  }

  main {
    min-height: calc(100vh - 72px);
  }

  img {
    max-width: 100%;
    display: block;
  }
</style>
