---
import Layout from '../layouts/Layout.astro';

const resources = [
  {
    icon: '🩺',
    title: 'Finding Healthcare',
    description:
      'Learn how to find a family doctor, use a walk-in clinic, and access virtual care.',
  },
  {
    icon: '🚑',
    title: 'Emergency Care',
    description:
      'Understand when to call 911, visit an emergency department, or seek less urgent care.',
  },
  {
    icon: '💊',
    title: 'Medications',
    description:
      'Learn about prescriptions, pharmacies, refills, and how to take medicines safely.',
  },
  {
    icon: '🧠',
    title: 'Mental Health',
    description:
      'Find plain-language information about mental health support and community services.',
  },
  {
    icon: '👶',
    title: 'Family Health',
    description:
      'Explore information about pregnancy, children’s health, vaccinations, and screening.',
  },
  {
    icon: '💳',
    title: 'Health Coverage',
    description:
      'Learn how provincial health insurance works and which services may be covered.',
  },
];
---

<Layout>
  <header class="site-header">
    <div class="nav-container">
      <a class="brand" href="/">
        <span class="brand-icon">🌍</span>
        <span>Newcomer Health</span>
      </a>

      <nav aria-label="Main navigation">
        <a href="#resources">Resources</a>
        <a href="#workshops">Workshops</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="hero-content">
        <p class="eyebrow">Accessible health information for newcomers</p>

        <h1>Navigate Canadian healthcare with confidence.</h1>

        <p class="hero-description">
          Plain-language resources, multilingual education, and community
          workshops designed to help newcomers understand and use the healthcare
          system.
        </p>

        <div class="hero-actions">
          <a class="button primary" href="#resources">Explore resources</a>
          <a class="button secondary" href="#workshops">View workshops</a>
        </div>

        <p class="disclaimer">
          Educational information only. This website does not replace medical
          advice from a qualified healthcare professional.
        </p>
      </div>

      <div class="hero-card" aria-hidden="true">
        <div class="illustration">🏥</div>
        <h2>Healthcare made clearer</h2>
        <p>
          Understand where to go, what to expect, and how to ask questions about
          your care.
        </p>
      </div>
    </section>

    <section class="section" id="resources">
      <div class="section-heading">
        <p class="eyebrow">Start here</p>
        <h2>Health information for everyday needs</h2>
        <p>
          Explore practical guides created to make the healthcare system easier
          to understand.
        </p>
      </div>

      <div class="resource-grid">
        {
          resources.map((resource) => (
            <article class="resource-card">
              <span class="resource-icon">{resource.icon}</span>
              <h3>{resource.title}</h3>
              <p>{resource.description}</p>
              <a href="#">Learn more <span aria-hidden="true">→</span></a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="workshop-section" id="workshops">
      <div>
        <p class="eyebrow">Community education</p>
        <h2>Attend a health literacy workshop</h2>
        <p>
          Our workshops help newcomers ask informed questions, understand health
          services, and make confident decisions.
        </p>
      </div>

      <a class="button light" href="#">See upcoming workshops</a>
    </section>

    <section class="section about-section" id="about">
      <div>
        <p class="eyebrow">Our mission</p>
        <h2>Making healthcare information easier to access</h2>
      </div>

      <p>
        The Newcomer Health Literacy Initiative supports newcomers through
        understandable, culturally responsive health education. We work with
        community members and healthcare professionals to identify common
        barriers and create practical resources.
      </p>
    </section>
  </main>

  <footer id="contact">
    <div>
      <strong>Newcomer Health Literacy Initiative</strong>
      <p>Helping newcomers navigate healthcare with confidence.</p>
    </div>

    <div>
      <strong>Contact</strong>
      <p>Contact information coming soon.</p>
    </div>
  </footer>
</Layout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    background: #f8fafc;
    color: #16324f;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid #dce7ea;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
  }

  .nav-container {
    max-width: 1180px;
    min-height: 72px;
    margin: auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #123b4a;
    font-weight: 800;
    text-decoration: none;
  }

  .brand-icon {
    font-size: 1.6rem;
  }

  nav {
    display: flex;
    gap: 28px;
  }

  nav a {
    color: #365b68;
    font-size: 0.95rem;
    font-weight: 650;
    text-decoration: none;
  }

  nav a:hover {
    color: #087f8c;
  }

  .hero {
    max-width: 1180px;
    margin: auto;
    padding: 96px 24px 88px;
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    align-items: center;
    gap: 72px;
  }

  .eyebrow {
    margin: 0 0 14px;
    color: #087f8c;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 760px;
    margin-bottom: 24px;
    color: #123b4a;
    font-size: clamp(2.7rem, 6vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.055em;
  }

  .hero-description {
    max-width: 710px;
    color: #52707b;
    font-size: 1.2rem;
    line-height: 1.75;
  }

  .hero-actions {
    margin: 34px 0 24px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .button {
    min-height: 48px;
    padding: 13px 21px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 2px solid transparent;
    border-radius: 10px;
    font-weight: 750;
    text-decoration: none;
  }

  .primary {
    background: #087f8c;
    color: white;
  }

  .primary:hover {
    background: #066b76;
  }

  .secondary {
    border-color: #b9d2d7;
    background: white;
    color: #164e5a;
  }

  .secondary:hover {
    border-color: #087f8c;
  }

  .disclaimer {
    max-width: 680px;
    color: #70868e;
    font-size: 0.82rem;
    line-height: 1.5;
  }

  .hero-card {
    padding: 44px 38px;
    border: 1px solid #b9dcdd;
    border-radius: 28px;
    background: linear-gradient(145deg, #e6f6f4, #ffffff);
    box-shadow: 0 24px 70px rgba(22, 75, 82, 0.12);
  }

  .illustration {
    margin-bottom: 22px;
    font-size: 5rem;
  }

  .hero-card h2 {
    margin-bottom: 14px;
    font-size: 1.7rem;
  }

  .hero-card p {
    margin-bottom: 0;
    color: #55727b;
    line-height: 1.7;
  }

  .section {
    max-width: 1180px;
    margin: auto;
    padding: 90px 24px;
  }

  .section-heading {
    max-width: 700px;
    margin-bottom: 42px;
  }

  .section-heading h2,
  .about-section h2,
  .workshop-section h2 {
    margin-bottom: 16px;
    color: #123b4a;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.035em;
  }

  .section-heading > p:last-child,
  .about-section > p,
  .workshop-section p {
    color: #58747e;
    line-height: 1.75;
  }

  .resource-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .resource-card {
    padding: 30px;
    border: 1px solid #dde8eb;
    border-radius: 18px;
    background: white;
    box-shadow: 0 10px 30px rgba(27, 65, 75, 0.05);
  }

  .resource-card:hover {
    border-color: #8dc5c8;
    transform: translateY(-3px);
    transition: 160ms ease;
  }

  .resource-icon {
    display: block;
    margin-bottom: 20px;
    font-size: 2rem;
  }

  .resource-card h3 {
    margin-bottom: 12px;
    font-size: 1.25rem;
  }

  .resource-card p {
    min-height: 96px;
    color: #607983;
    line-height: 1.65;
  }

  .resource-card a {
    color: #087f8c;
    font-weight: 750;
    text-decoration: none;
  }

  .workshop-section {
    max-width: 1132px;
    margin: 36px auto;
    padding: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 36px;
    border-radius: 26px;
    background: #123b4a;
    color: white;
  }

  .workshop-section h2,
  .workshop-section p {
    color: white;
  }

  .workshop-section p {
    max-width: 720px;
    margin-bottom: 0;
    opacity: 0.83;
  }

  .light {
    flex-shrink: 0;
    background: white;
    color: #123b4a;
  }

  .about-section {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: 80px;
    align-items: start;
  }

  .about-section > p {
    font-size: 1.08rem;
  }

  footer {
    margin-top: 60px;
    padding: 52px max(24px, calc((100vw - 1132px) / 2));
    display: flex;
    justify-content: space-between;
    gap: 40px;
    border-top: 1px solid #dce7ea;
    background: white;
    color: #57717a;
  }

  footer strong {
    color: #123b4a;
  }

  footer p {
    margin: 8px 0 0;
  }

  @media (max-width: 850px) {
    nav {
      display: none;
    }

    .hero {
      padding-top: 64px;
      grid-template-columns: 1fr;
      gap: 46px;
    }

    .resource-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .workshop-section,
    .about-section {
      grid-template-columns: 1fr;
    }

    .workshop-section {
      margin: 24px;
      padding: 42px 30px;
      align-items: flex-start;
      flex-direction: column;
    }
  }

  @media (max-width: 560px) {
    .resource-grid {
      grid-template-columns: 1fr;
    }

    .resource-card p {
      min-height: auto;
    }

    footer {
      flex-direction: column;
    }
  }
</style>